{%- comment -%}
  Phase 1: schema-only block. The section itself iterates section.blocks
  to render both the tab button and the (dummy) panel inline, using a
  consistent forloop.index0 — eliminating content_for/forloop scope mismatch.
{%- endcomment -%}

{% schema %}
{
  "name": "Ornevo services tab",
  "settings": [
    {
      "type": "header",
      "content": "Tab"
    },
    {
      "type": "text",
      "id": "tab_label_desktop",
      "label": "Etiqueta del tab (desktop)",
      "info": "Ej: SEO, Performance, Desarrollo"
    },
    {
      "type": "image_picker",
      "id": "tab_icon_number",
      "label": "Número del tab (SVG)",
      "info": "SVG: 01, 02… Se muestra en móvil. Si está vacío, se usa el número de posición."
    }
  ],
  "presets": [
    {
      "name": "Ornevo services tab"
    }
  ]
}
{% endschema %}
